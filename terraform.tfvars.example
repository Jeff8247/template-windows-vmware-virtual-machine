# vCenter connection
# Tip: avoid storing passwords here — use environment variables instead:
#   export TF_VAR_vsphere_password="..."
#   export TF_VAR_windows_admin_password="..."
vsphere_server           = "vcenter.example.com"
vsphere_user             = "administrator@vsphere.local"
vsphere_password         = "<vsphere-password>"
vsphere_allow_unverified_ssl = false

# Infrastructure placement
datacenter        = "dc01"
cluster           = "cluster01"
resource_pool     = null           # e.g. "rp-dev" or null to use cluster root
datastore         = "datastore01"  # set one of datastore or datastore_cluster
datastore_cluster = null
host              = null           # set if targeting a specific host instead of a cluster

# VM identity
vm_name    = "win-server-01"
vm_folder  = "VMs/Windows"        # vSphere inventory folder path, or null
annotation = "Deployed by Terraform"
tags       = {}                    # e.g. { "Environment" = "Production" }

# Template
template_name       = "WIN2022-TEMPLATE"
template_datacenter = null         # only needed if template is in a different datacenter
linked_clone        = false

# CPU
num_cpus             = 2
num_cores_per_socket = 1
cpu_hot_add_enabled  = false
cpu_reservation      = 0
cpu_limit            = -1
cpu_share_level      = "normal"

# Memory (MB, must be a multiple of 4)
memory                 = 4096
memory_hot_add_enabled = false
memory_reservation     = 0
memory_limit           = -1
memory_share_level     = "normal"

# Storage
scsi_type             = "pvscsi"
scsi_controller_count = 1

disks = [
  {
    label            = "disk0"
    size             = 100   # GB
    unit_number      = 0
    thin_provisioned = true
    eagerly_scrub    = false
  }
]

# Networking
network_interfaces = [
  {
    network_name = "VM Network"
    adapter_type = "vmxnet3"
  }
]

# Static IP (leave ip_settings = [] for DHCP)
ip_settings = [
  # {
  #   ipv4_address = "192.168.1.100"
  #   ipv4_netmask = 24
  # }
]
ipv4_gateway    = null             # e.g. "192.168.1.1"
dns_servers     = ["8.8.8.8", "8.8.4.4"]
dns_suffix_list = []               # e.g. ["example.com"]

# Guest OS - Windows
guest_id      = "windows2022srvNext_64Guest"
computer_name = "WIN-SERVER-01"   # max 15 characters
domain        = "example.com"     # DNS domain suffix (not AD domain join)
time_zone     = 85                # 85 = Eastern Standard Time

windows_admin_password = "<windows-admin-password>"

# Active Directory domain join (set windows_domain = null to skip)
windows_domain          = null    # e.g. "corp.example.com"
windows_domain_user     = null    # e.g. "svc-domain-join"
windows_domain_password = null
windows_workgroup       = "WORKGROUP"

windows_auto_logon       = false
windows_auto_logon_count = 1
windows_run_once         = []     # e.g. ["powershell.exe -File C:\\setup.ps1"]

# Hardware
firmware         = "efi"
hardware_version = null           # null = keep template version
enable_disk_uuid = true
vbs_enabled      = false

# Timeouts
wait_for_guest_net_timeout  = 5
wait_for_guest_net_routable = true
customize_timeout           = 60

# Extra VMX config (optional)
extra_config = {}
