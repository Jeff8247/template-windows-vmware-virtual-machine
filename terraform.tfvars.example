# vCenter connection — set passwords via environment variables:
#   export TF_VAR_vsphere_password="..."
#   export TF_VAR_windows_admin_password="..."
vsphere_server = "vcenter.example.com"
vsphere_user   = "administrator@vsphere.local"

# Infrastructure placement
datacenter = "dc01"
cluster    = "cluster01"
datastore  = "datastore01"

# VM identity
vm_name   = "win-server-01"
vm_folder = "VMs/Windows"

# Template
template_name = "WIN2022-TEMPLATE"

# Compute
num_cpus = 2
memory   = 4096

# Storage
disks = [
  {
    label       = "disk0"
    size        = 100
    unit_number = 0
  }
]

# Networking
network_interfaces = [{ network_name = "VM Network" }]

# Static IP — remove ip_settings block entirely for DHCP
ip_settings     = [{ ipv4_address = "192.168.1.100", ipv4_netmask = 24 }]
ipv4_gateway    = "192.168.1.1"
dns_servers     = ["192.168.1.10", "192.168.1.11"]
dns_suffix_list = ["example.com"]

# Guest OS
guest_id      = "windows2022srvNext_64Guest"
computer_name = "WIN-SERVER-01"   # max 15 characters
time_zone     = 85                # 85 = Eastern Standard Time

# Active Directory domain join — remove block to stay in workgroup
# windows_domain      = "corp.example.com"
# windows_domain_user = "svc-domain-join"
# windows_domain_ou   = "OU=Servers,OU=IT,DC=corp,DC=example,DC=com"   # null = default Computers container
# windows_domain_password via TF_VAR_windows_domain_password

# Hardware
firmware             = "efi"
tools_upgrade_policy = "upgradeAtPowerCycle"
